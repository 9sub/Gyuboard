<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ssafy.edu.model.mapper.MemberMapper">

    <select id="login" parameterType="com.ssafy.edu.model.dto.MemberDto"
    	resultType="com.ssafy.edu.model.dto.MemberDto">
    	SELECT
    		writer,
    		name,
    		password,
    		email,
    		regidate
    	FROM gueuser
    	WHERE password = #{password} and writer = #{writer}
    	
    </select>

</mapper>

